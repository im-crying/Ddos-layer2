loading_animation() {
    local text="$1"
    echo -ne "${YELLOW}[*] ${text} ${NC}"
    local spin='⣾⣽⣻⢿⡿⣟⣯⣷'
    for i in {1..10}; do
        echo -ne "\b${spin:$((i % 8)):1}"
        sleep 0.1
    done
    echo -e "\b${GREEN}✓${NC}"
}

